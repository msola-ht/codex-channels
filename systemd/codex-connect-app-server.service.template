[Unit]
Description=Codex Connect App Server

[Service]
Type=simple
WorkingDirectory=__WORKDIR__
ExecStart=__CODEX_BINARY__ app-server --listen __SOCKET_URI__
Environment="PATH=__SYSTEMD_PATH__"
Environment="HTTP_PROXY=__HTTP_PROXY__"
Environment="HTTPS_PROXY=__HTTPS_PROXY__"
Environment="ALL_PROXY=__ALL_PROXY__"
Environment="NO_PROXY=__NO_PROXY__"
Environment="http_proxy=__http_proxy__"
Environment="https_proxy=__https_proxy__"
Environment="all_proxy=__all_proxy__"
Environment="no_proxy=__no_proxy__"
UMask=0077
Restart=always
RestartSec=5

[Install]
WantedBy=default.target

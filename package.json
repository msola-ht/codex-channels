{
  "name": "@hegenai/codexc",
  "version": "0.145.0",
  "description": "Telegram gateway for a shared Codex App Server",
  "keywords": [
    "codex",
    "telegram",
    "gateway",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msola-ht/codex-channels.git"
  },
  "homepage": "https://github.com/msola-ht/codex-channels#readme",
  "bugs": {
    "url": "https://github.com/msola-ht/codex-channels/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "codexc": "bin/codexc.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "src/codex-protocol/version.json",
    "launchd/",
    "runtime/",
    "systemd/",
    "scripts/",
    "config.example.toml",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "node scripts/prepare-package.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "verify:commit": "node scripts/verify-commit.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "version:sync": "node scripts/sync-gateway-version.mjs",
    "check": "tsc -p tsconfig.json --noEmit && node scripts/check-gateway-version.mjs",
    "dev": "tsx src/main.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "start": "node dist/main.js",
    "test": "vitest run --config vitest.config.ts",
    "test:package": "npm run build && node scripts/smoke-package.mjs && node scripts/smoke-source-prepare.mjs",
    "test:watch": "vitest --config vitest.config.ts",
    "protocol:generate": "node scripts/generate-protocol.mjs",
    "protocol:check": "node scripts/check-protocol.mjs",
    "release:check": "node scripts/check-release-tag.mjs",
    "lint": "eslint src tests bin runtime scripts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "launchd:install": "node scripts/install-launchd.mjs",
    "systemd:install": "node scripts/install-systemd.mjs",
    "remote": "node scripts/codex-remote.mjs",
    "workspace:add": "node scripts/workspace-add.mjs",
    "service:setup": "npm run build && node bin/codexc.mjs service install",
    "service:start": "node bin/codexc.mjs service start",
    "service:stop": "node bin/codexc.mjs service stop",
    "service:reload": "node bin/codexc.mjs service reload",
    "service:uninstall": "node bin/codexc.mjs service uninstall",
    "service:restart": "node bin/codexc.mjs service restart",
    "service:status": "node bin/codexc.mjs service status"
  },
  "dependencies": {
    "grammy": "^1.45.1",
    "https-proxy-agent": "^9.1.0",
    "pino": "^10.3.1",
    "smol-toml": "^1.7.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.0.16"
  }
}

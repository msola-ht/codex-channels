{
  "name": "@hegenai/codexc",
  "version": "0.2.1",
  "description": "Telegram gateway for a shared Codex App Server",
  "keywords": [
    "codex",
    "telegram",
    "gateway",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msola-ht/codex-channels.git"
  },
  "homepage": "https://github.com/msola-ht/codex-channels#readme",
  "bugs": {
    "url": "https://github.com/msola-ht/codex-channels/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "codexc": "bin/codexc.mjs",
    "codex-connect": "bin/codexc.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "src/codex-protocol/version.json",
    "launchd/",
    "scripts/",
    ".env.example",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.build.json",
    "prepare": "node scripts/prepare-package.mjs",
    "version": "node scripts/sync-gateway-version.mjs",
    "check": "tsc -p tsconfig.json --noEmit && node scripts/check-gateway-version.mjs",
    "dev": "tsx src/main.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "start": "node dist/main.js",
    "test": "vitest run --config vitest.config.ts",
    "test:package": "npm run build && node scripts/smoke-package.mjs",
    "test:watch": "vitest --config vitest.config.ts",
    "protocol:generate": "node scripts/generate-protocol.mjs",
    "protocol:check": "node scripts/check-protocol.mjs",
    "release:check": "node scripts/check-release-tag.mjs",
    "launchd:install": "node scripts/install-launchd.mjs",
    "remote": "node scripts/codex-remote.mjs",
    "workspace:add": "node scripts/workspace-add.mjs",
    "service:setup": "npm run build && npm run launchd:install && zsh scripts/launchd-control.sh install",
    "service:start": "zsh scripts/launchd-control.sh start",
    "service:stop": "zsh scripts/launchd-control.sh stop",
    "service:uninstall": "zsh scripts/launchd-control.sh uninstall",
    "service:restart": "zsh scripts/launchd-control.sh restart",
    "service:status": "zsh scripts/launchd-control.sh status"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "grammy": "^1.38.3",
    "https-proxy-agent": "^9.1.0",
    "pino": "^10.3.1",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}

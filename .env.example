# 从 @BotFather 获取。不要提交真实 Token。
TELEGRAM_BOT_TOKEN=

# 允许访问机器人的 Telegram 用户 ID，多个 ID 用英文逗号分隔。
TELEGRAM_ALLOWED_USER_IDS=123456789

# 可选。设置后 Telegram 强制走该 HTTP(S) 代理；未设置时读取 HTTPS_PROXY/HTTP_PROXY。
TELEGRAM_PROXY_URL=http://127.0.0.1:7890

# Codex CLI 与工作目录。
CODEX_BINARY=codex
CODEX_WORKDIR=/absolute/path/to/project

# 独立 Codex App Server 的 Unix Socket 绝对路径。
# 启动示例：codex app-server --listen unix:///absolute/path/codex-app-server.sock
CODEX_SOCKET_PATH=/absolute/path/to/codex-app-server.sock

# 可选：留空时使用本机 Codex 默认模型。
CODEX_MODEL=

# 只允许 read-only 或 workspace-write。
CODEX_BRIDGE_SANDBOX=workspace-write

# Telegram 审批按钮超时（秒），范围 30-3600；超时自动拒绝。
APPROVAL_TIMEOUT_SECONDS=300

LOG_LEVEL=info

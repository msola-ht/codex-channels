<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.msola.codex-gateway</string>
  <key>ProgramArguments</key>
  <array>
    <string>__NODE_BINARY__</string>
    <string>__PROJECT_DIR__/dist/gateway/src/main.js</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>5</integer>
  <key>StandardOutPath</key>
  <string>__RUNTIME_DIR__/gateway.log</string>
  <key>StandardErrorPath</key>
  <string>__RUNTIME_DIR__/gateway.error.log</string>
</dict>
</plist>
